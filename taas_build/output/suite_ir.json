{
  "suite_name": "Password Reset & Auth",
  "base_url": "https://demo-app.local",
  "cases": [
    {
      "name": "Story happy path - User can reset password via email link",
      "category": "happy_path",
      "source": "story:PROJ-123",
      "tags": [
        "story",
        "happy_path"
      ],
      "steps": [
        {
          "action": "navigate",
          "locator": null,
          "value": "/",
          "description": "Open app for: User can reset password via email link",
          "timeout": 10
        },
        {
          "action": "fill",
          "locator": {
            "strategy": "name",
            "value": "email"
          },
          "value": "sample_value",
          "description": "AC: User can enter their email address",
          "timeout": 10
        },
        {
          "action": "click",
          "locator": {
            "strategy": "css",
            "value": "button[type=submit]"
          },
          "value": null,
          "description": "AC: User can click the reset button",
          "timeout": 10
        },
        {
          "action": "assert_text",
          "locator": {
            "strategy": "css",
            "value": "body"
          },
          "value": "a confirmation message: Reset link sent",
          "description": "AC (verify): User should see a confirmation message: Reset link sent",
          "timeout": 10
        },
        {
          "action": "screenshot",
          "locator": null,
          "value": null,
          "description": "Capture final state",
          "timeout": 10
        }
      ]
    },
